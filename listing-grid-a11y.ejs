<%
// Custom grid listing template with h2 for card titles (accessibility fix)
// Uses only the `items` array available in Quarto custom listing templates.
// Avoids listing.utilities (Quarto-internal, not available in custom templates).
const cols = (typeof listing !== 'undefined' && listing['grid-columns']) ? listing['grid-columns'] : 3;
const align = (typeof listing !== 'undefined' && listing['grid-item-align']) ? listing['grid-item-align'] : 'left';
const hideBorders = typeof listing !== 'undefined' && listing['grid-item-border'] === false;
const imagePlaceholder = (typeof listing !== 'undefined' && listing['image-placeholder']) ? listing['image-placeholder'] : '';
%>
<div class="list grid quarto-listing-cols-<%= cols %>">
<% for (const item of items) { %>
<%
const flexJustify = item.author && item.date ? 'justify' : item.author ? 'start' : 'end';
%>
<div class="g-col-1">
<a href="<%= item.path %>" class="quarto-grid-link" aria-label="<%= item.title %>">
<div class="quarto-grid-item card h-100 card-<%= align %><%= hideBorders ? ' borderless' : '' %>">

<% if (item.image) { %>
<p class="card-img-top">
  <img src="<%= item.image %>" class="thumbnail-image card-img" alt="<%= item['image-alt'] || '' %>">
</p>
<% } else if (imagePlaceholder) { %>
<p class="card-img-top">
  <img src="<%= imagePlaceholder %>" class="thumbnail-image card-img" alt="">
</p>
<% } %>

<div class="card-body post-contents">

<% if (item.title) { %>
<h2 class="no-anchor card-title listing-title"><%= item.title %></h2>
<% } %>

<% if (item.subtitle) { %>
<div class="card-subtitle listing-subtitle"><%= item.subtitle %></div>
<% } %>

<% if (item['reading-time']) { %>
<div class="listing-reading-time card-text text-muted"><%= item['reading-time'] %></div>
<% } %>

<% if (item.description) { %>
<div class="card-text listing-description delink">
  <%= item.description %>
</div>
<% } %>

<% if (item.author || item.date) { %>
<div class="card-attribution card-text-small <%= flexJustify %>">
<% if (item.author) { %>
<div class="listing-author"><%= item.author %></div>
<% } %>
<% if (item.date) { %>
<div class="listing-date"><%= item.date %></div>
<% } %>
</div>
<% } %>

</div>

</div>
</a>
</div>
<% } %>
</div>
